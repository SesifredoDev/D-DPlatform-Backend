    server: {
        type: mongoose.Schema.Types.ObjectId,
        ref: "Server",
        index: true
    },

    name: { type: String, required: true },

    icon: { type: String, required: true },
    type: {
        type: String,
        enum: ["text", "call", "map", "whisper"], // whisper is a private channel between a user and the DM
